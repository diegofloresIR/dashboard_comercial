# OPENAI_API_KEY: Required for the Copilot AI assistant (gpt-4o-mini).
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Configuration
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# GoHighLevel OAuth Configuration
GHL_CLIENT_ID="your-ghl-client-id"
GHL_CLIENT_SECRET="your-ghl-client-secret"
GHL_WEBHOOK_SECRET="your-webhook-secret"

# GoHighLevel Internal Integration (Alternative to OAuth)
GHL_LOCATION_ID="your-location-id"
GHL_API_KEY="your-api-key"
